# Root of your SS13 repository
PROJECT_ROOT=D:\servers emulators\ss13\Bubberstation

# Argos source/target language codes
SOURCE_ARGOS_CODE=en
TARGET_ARGOS_CODE=pb

# Path to your .argosmodel (optional if already installed in Argos)
ARGOS_MODEL_PATH=./translate-en_pb-1_9.argosmodel
AUTO_INSTALL_MODEL=true
ARGOS_DATA_DIR=./.argos

# File scanning
INCLUDE_EXTENSIONS=.dm,.js,.jsx,.ts,.tsx
EXCLUDE_DIRS=.git,node_modules,code/__DEFINES,tgui/packages/tgui-panel/dist,tgui/packages/tgui/dist,tools/ss13 translator/.argos,tools/ss13 translator/build,tools/ss13 translator/dist

# Optional: after translation, run biome format on only the changed files.
# Set to a biome binary path (e.g. "npx @biomejs/biome" or "bunx biome").
# Uses --formatter-enabled=true --linter-enabled=false --assist-enabled=false
# to avoid the damaging --unsafe organizeImports reformatting.
# Leave empty (default) to skip biome entirely.
# BIOME_FIX_CMD=bunx biome

# Runtime
DRY_RUN=true
WRITE_REPORT=true
REPORT_PATH=./translation_report.txt
LOG_LEVEL=INFO
SHOW_PROGRESS_BAR=true
MAX_WORKERS=8
SKIP_PORTUGUESE=true


FILE_CACHE_PATH=./.cache/files_cache.json
RESET_FILE_CACHE_ON_START=false
FILE_CACHE_SAVE_EVERY=0
MAX_FILE_BYTES=1048576
TRANSLATOR_POOL_SIZE=4

MAX_LINE_CHARS=6000

SKIP_DM_STRINGS_WITH_BRACKETS=true

# Review log (JSONL) - records original line, translated line, file:line location
REVIEW_LOG_PATH=./.cache/review.jsonl

# Persistent translation cache - avoids re-translating the same source text across runs
PERSISTENT_TRANSLATION_CACHE_PATH=./.cache/translation_cache.json
# Save persistent cache every N files (0 = only on completion)
PERSISTENT_TRANSLATION_CACHE_SAVE_EVERY=0
