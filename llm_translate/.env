# Original (English) SS13 directory -- the clean unmodified backup
ORIGINAL_ROOT=D:\servers emulators\ss13\Bubberstation-backup

# Target (translated) SS13 directory -- the project being worked on
TARGET_ROOT=D:\servers emulators\ss13\Bubberstation

# LLM API
LLM_API_BASE=http://127.0.0.1:1234/v1
LLM_API_KEY=not-needed
LLM_MODEL=local-model
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=8192
LLM_TIMEOUT=300

# Languages
SOURCE_LANG=en
TARGET_LANG=pt-BR

# File scanning
INCLUDE_EXTENSIONS=.dm,.js,.jsx,.ts,.tsx
EXCLUDE_DIRS=.git,node_modules,code/__DEFINES,tgui/packages/tgui-panel/dist,tgui/packages/tgui/dist
